# Required: HMAC for /verify signatures (min 16 chars)
HMAC_SECRET=change-this-to-a-long-random-secret

# Strongly recommended in production: protects /create and /toggle
#   Header: Authorization: Bearer <value>   OR   x-admin-key: <value>
ADMIN_API_KEY=

# Render sets PORT automatically; local default is 3000
# PORT=3000

# Optional: comma-separated origins for browser clients (otherwise permissive dev CORS)
# CORS_ORIGIN=https://your-site.example,http://localhost:5173

# Discord bot integration (optional)
# API_BASE_URL=https://your-api.onrender.com
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
# DISCORD_GUILD_ID=
